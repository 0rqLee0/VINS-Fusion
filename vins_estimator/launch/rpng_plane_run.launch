<launch>
    <!-- 参数 -->
    <arg name="config_path" default="$(find vins)/../config/rpng_plane/rpng_plane_mono_imu_config.yaml"/>
    <arg name="bag_file" doc="bag文件完整路径"/>
    <arg name="enable_rviz" default="false" doc="是否启动rviz"/>
    <arg name="enable_loop" default="false" doc="是否启用回环检测"/>

    <!-- VINS 节点 -->
    <node name="vins_node" pkg="vins" type="vins_node" output="screen"
          args="$(arg config_path)"/>

    <!-- 回环检测 (可选) -->
    <group if="$(arg enable_loop)">
        <node name="loop_fusion_node" pkg="loop_fusion" type="loop_fusion_node" output="screen"
              args="$(arg config_path)"/>
    </group>

    <!-- rviz (可选) -->
    <group if="$(arg enable_rviz)">
        <node name="rviz" pkg="rviz" type="rviz" output="log"
              args="-d $(find vins)/../config/vins_rviz_config.rviz"/>
    </group>

    <!-- rosbag 回放 -->
    <node name="rosbag_play" pkg="rosbag" type="play" output="screen"
          args="--clock -d 3 $(arg bag_file)"
          required="true"/>
</launch>
